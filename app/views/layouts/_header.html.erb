<header class="navbar-modern">
  <div class="container py-3">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
      <a href="/" class="d-flex align-items-center text-decoration-none text-dark fw-semibold">
        <span class="brand-mark">↗</span>
        <span class="ms-2">LinkFlow</span>
      </a>
      <div class="d-flex align-items-center gap-2">
        <a href="/" class="nav-link px-2 text-muted">Home</a>
        <% if account_signed_in? %>
          <a href="/<%= current_account.landingpage_url %>" class="btn btn-outline-primary">My page</a>
        <% end %>
        <% unless account_signed_in? %>
          <a href="/accounts/sign_in" class="btn btn-outline-primary">Login</a>
          <a href="/accounts/sign_up" class="btn btn-primary">Sign up</a>
        <% end %>
        <% if account_signed_in? %>
          <%= button_to "Sign out", destroy_account_session_path, method: :delete, class: "btn btn-primary" %>
        <% end %>
      </div>
    </div>
  </div>
</header>
