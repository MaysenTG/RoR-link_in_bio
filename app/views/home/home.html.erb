<% if notice %>
  <div class="container mt-4">
    <div class="alert alert-modern" role="alert">
      <%= notice.html_safe %>
    </div>
  </div>
<% end %>

<section class="container py-5">
  <div class="hero-panel">
    <div class="row align-items-center g-5">
      <div class="col-lg-7">
        <span class="hero-badge">✨ Create a polished link-in-bio in minutes</span>
        <h1 class="display-4 fw-bold mb-3">Turn your profile into a beautiful home for every link.</h1>
        <p class="lead mb-4">Add custom cards, visuals, and colors to make your page feel as personal as your brand.</p>
        <div class="d-flex flex-wrap gap-3">
          <a href="/accounts/sign_up" class="btn btn-light btn-lg text-primary">Start for free</a>
          <a href="/accounts/sign_in" class="btn btn-outline-light btn-lg">Login</a>
        </div>
      </div>
      <div class="col-lg-5">
        <div class="feature-card p-4">
          <div class="d-flex align-items-center gap-3 mb-4">
            <div class="rounded-circle bg-primary bg-opacity-10 p-3 text-primary">
              <i class="bi bi-person-circle fs-4"></i>
            </div>
            <div>
              <h5 class="mb-0">Your new profile</h5>
              <p class="mb-0 text-muted">A clean, modern preview</p>
            </div>
          </div>
          <div class="preview-card">
            <div class="preview-top"></div>
            <div class="preview-content">
              <div class="preview-avatar"></div>
              <div class="preview-line short"></div>
              <div class="preview-line"></div>
              <div class="preview-link"></div>
              <div class="preview-link"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="container pb-5">
  <div class="row g-4">
    <div class="col-md-4">
      <div class="feature-card p-4 h-100">
        <div class="feature-icon mb-3"><i class="bi bi-palette"></i></div>
        <h4 class="mb-2">Custom theme</h4>
        <p class="text-muted mb-0">Choose colors and a style that matches your personality or business.</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="feature-card p-4 h-100">
        <div class="feature-icon mb-3"><i class="bi bi-link-45deg"></i></div>
        <h4 class="mb-2">Beautiful blocks</h4>
        <p class="text-muted mb-0">Organize links into polished cards with images and clear descriptions.</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="feature-card p-4 h-100">
        <div class="feature-icon mb-3"><i class="bi bi-phone"></i></div>
        <h4 class="mb-2">Mobile ready</h4>
        <p class="text-muted mb-0">Your page looks great on phones, tablets, and desktops without extra work.</p>
      </div>
    </div>
  </div>
</section>

<div class="container">
  <footer class="footer-shell">
    <p class="mb-0">© Maysen Greenwood</p>
    <a href="/" class="text-muted">Home</a>
  </footer>
</div>
