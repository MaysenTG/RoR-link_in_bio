<div id="main-bg-color-container" class="landingpage-page">
  <section class="container py-4 py-md-5">
    <div class="row justify-content-center">
      <div class="col-md-10 col-lg-8">
        <div class="profile-card" style="background: linear-gradient(135deg, rgba(255,255,255,.95), rgba(255,255,255,.8)); border-color: rgba(15, 23, 42, .08);">
          <div class="text-center">
            <div class="mb-4">
              <% if Account.find(@landingpage.account_id).avatar.attached? %>
                <img src="https://storage.googleapis.com/rails_link_in_bio_images/<%= Account.find(@landingpage.account_id).avatar.key %>" class="profile-avatar" alt="Profile photo" />
              <% else %>
                <img id="profile-image" src="https://mdbcdn.b-cdn.net/img/Photos/new-templates/bootstrap-chat/ava2-bg.webp" class="profile-avatar" alt="Profile photo" />
              <% end %>
            </div>
            <h2 class="mb-2"><%= Account.find(@landingpage.account_id).name %></h2>
            <p class="text-muted mb-4">@<%= Account.find(@landingpage.account_id).landingpage_url %></p>
          </div>

          <div class="d-flex justify-content-center flex-wrap gap-2 mb-3">
            <% if @socials["facebook"] != "" %>
              <a href="<%= @socials["facebook"] %>" target="_blank" class="social-pill">
                <i class="bi bi-facebook"></i>
              </a>
            <% end %>
            <% if @socials["twitter"] != "" %>
              <a href="<%= @socials["twitter"] %>" target="_blank" class="social-pill">
                <i class="bi bi-twitter"></i>
              </a>
            <% end %>
            <% if @socials["github"] != "" %>
              <a href="<%= @socials["github"] %>" target="_blank" class="social-pill">
                <i class="bi bi-github"></i>
              </a>
            <% end %>
            <% if @socials["linkedin"] != "" %>
              <a href="<%= @socials["linkedin"] %>" target="_blank" class="social-pill">
                <i class="bi bi-linkedin"></i>
              </a>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container pb-4">
    <% if @blocks.any? %>
      <div class="link-list">
        <% @blocks.each do |block| %>
          <a href="<% if block.url.index('http://') === 0 || block.url.index('https://') === 0 %><%= block.url %><% else %>https://<%= block.url %><% end %>" target="_blank" class="link-card" aria-label="Open <%= block.title %>">
            <% if block.block_image.attached? %>
              <img src="https://storage.googleapis.com/rails_link_in_bio_images/<%= block.block_image.key %>" alt="Image for <%= block.title %>" />
            <% else %>
              <div class="link-icon"><i class="bi bi-arrow-up-right-circle"></i></div>
            <% end %>
            <div>
              <h6 class="link-title mb-1"><%= block.title %></h6>
              <p class="link-copy mb-0"><%= block.content %></p>
            </div>
          </a>
        <% end %>
      </div>
    <% else %>
      <div class="feature-card p-4 text-center">
        <p class="mb-0 text-muted">This profile is ready for links. Add your first block to get started.</p>
      </div>
    <% end %>
  </section>
</div>

<div class="container">
  <footer class="footer-shell">
    <p class="mb-0">© Maysen Greenwood</p>
    <div class="d-flex gap-3">
      <a href="/" class="text-muted">Home</a>
      <a href="/<%= @landingpage.url %>/edit" class="text-muted">Edit page</a>
    </div>
  </footer>
</div>
