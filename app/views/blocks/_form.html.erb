<%= form_with(model: block, multipart: true, html: { class: "block-form" }) do |form| %>
  <input type="hidden" name="landingpage_id" value="<%= @landingpage.id %>"/>
  <div class="block-editor-card list-group-item list-group-item-action d-flex gap-3 py-3" aria-current="true">
    <div class="row w-100 g-3">
      <div class="col-12 col-lg-2">
        <div class="d-flex flex-column h-100">
          <% if block.block_image.attached? %>
            <%= image_tag block.block_image, class: "img-fluid rounded shadow-sm", style: "margin: 0 auto; max-width: 7rem; height: 7rem; object-fit: cover;", data: { block_preview: true } %>
          <% else %>
            <img style="max-width: 7rem; height: 7rem; margin: 0 auto; object-fit: cover;" data-block-preview="true" src="https://upload.wikimedia.org/wikipedia/commons/3/3f/Placeholder_view_vector.svg" class="rounded img-fluid shadow-sm" />
          <% end %>
          <label for="block_image_<%= block.id.present? ? block.id : 'new' %>" class="form-label mt-2 mb-1 small text-muted">Image</label>
          <input class="form-control" type="file" id="block_image_<%= block.id.present? ? block.id : 'new' %>" name="block[block_image]" accept="image/*">
        </div>
      </div>
      <div class="col-12 col-lg-8">
        <div class="row g-3">
          <div class="col-12 col-md-6">
            <%= form.label :title, class: "form-label small text-muted" %>
            <%= form.text_field :title, placeholder: "e.g. My latest project", class: "form-control" %>
          </div>
          <div class="col-12 col-md-6">
            <%= form.label :url, class: "form-label small text-muted" %>
            <%= form.text_field :url, class: "form-control", placeholder: "https://example.com" %>
          </div>
          <div class="col-12">
            <%= form.label :content, class: "form-label small text-muted" %>
            <%= form.text_field :content, placeholder: "Short description", class: "form-control" %>
          </div>
        </div>
      </div>
      <div class="col-12 col-lg-2 d-flex flex-wrap justify-content-center align-items-center gap-2 action-stack">
        <button class="btn btn-success action-pill" type="submit" aria-label="Save block"><i class="bi bi-check-lg"></i></button>
        <% if block.id.nil? %>
          <button onclick="hideEditBlock(this, false); return false;" class="btn btn-secondary action-pill" type="button" aria-label="Cancel new block"><i class="bi bi-x-lg"></i></button>
        <% else %>
          <button onclick="hideEditBlock(this, true); return false;" class="btn btn-secondary action-pill" type="button" aria-label="Cancel editing"><i class="bi bi-x-lg"></i></button>
          <button data-id="<%= block.id %>" class="btn btn-danger action-pill" onclick="deleteBlock(this); return false;" type="button" aria-label="Delete block"><i class="bi bi-trash"></i></button>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
