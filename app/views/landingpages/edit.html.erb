<style>
  .drag-list-icon:hover {
    cursor: grab;
  }
</style>

<div class="editor-shell">
  <div class="container">
    <% if notice || alert %>
      <div class="alert alert-modern mb-4 <%= alert.present? ? 'alert-danger' : '' %>" role="alert">
        <%= (notice || alert).html_safe %>
      </div>
    <% end %>

    <div class="editor-hero mb-4">
      <div>
        <div class="editor-kicker">Editor workspace</div>
        <h1 class="mb-2">Craft your landing page</h1>
        <p class="text-muted mb-0">Update your profile, arrange your links, and tune the theme in one place.</p>
      </div>
      <a href="/<%= @landingpage.url %>" target="_blank" class="btn btn-primary">Preview live page</a>
    </div>

    <div class="editor-panel">
      <nav>
        <div class="nav nav-tabs editor-tabs" id="nav-tab" role="tablist">
          <button class="nav-link active" id="nav-main-tab" data-bs-toggle="tab" data-bs-target="#nav-main" type="button" role="tab" aria-controls="nav-main" aria-selected="true">Main page</button>
          <button class="nav-link" id="nav-theme-tab" data-bs-toggle="tab" data-bs-target="#nav-theme" type="button" role="tab" aria-controls="nav-theme" aria-selected="false">Theme</button>
        </div>
      </nav>
      <div class="tab-content p-4" id="nav-tabContent">
        <div class="tab-pane fade show active" id="nav-main" role="tabpanel" aria-labelledby="nav-main-tab" tabindex="0">
          <div style="background-color: <%= @landingpage.main_bg_colour %>" id="main-bg-color-container">
            <section id="profile-section" class="main_page_background_container">
              <div class="container py-4">
                <div class="row justify-content-center">
                  <div class="col-md-10 col-lg-8">
                    <div class="section-heading mb-3">
                      <div>
                        <h3 class="mb-1">Profile</h3>
                        <p class="mb-0 text-muted">Add your photo, name, and social links.</p>
                      </div>
                    </div>
                    <form enctype="multipart/form-data" data-turbo="false" class="edit_account" id="edit_account" action="/accounts" accept-charset="UTF-8" method="post">
                      <div class="card form-card" id="profile">
                        <div class="card-body text-center">
                          <div class="mt-3 mb-4">
                            <div class="d-flex flex-column justify-content-center image-edit-container">
                              <% if Account.find(@landingpage.account_id).avatar.attached? %>
                                <img src="https://storage.googleapis.com/rails_link_in_bio_images/<%= Account.find(@landingpage.account_id).avatar.key %>" class="profile-avatar" alt="Current profile" />
                              <% else %>
                                <img id="profile-image" src="https://mdbcdn.b-cdn.net/img/Photos/new-templates/bootstrap-chat/ava2-bg.webp" class="profile-avatar" alt="Current profile" />
                              <% end %>
                              <div class="mb-3 mt-3">
                                <label for="avatar" class="form-label">Choose profile picture</label>
                                <input class="form-control" name="account[avatar]" type="file" id="avatar">
                              </div>
                            </div>
                          </div>
                          <input type="hidden" name="_method" value="put" autocomplete="off">
                          <input type="hidden" name="id" value="<%= Account.find(@landingpage.account_id).id %>" >
                          <div class="mb-3 d-flex flex-column justify-content-evenly align-items-center">
                            <div class="mb-3">
                              <label for="account_name" class="form-label">Name</label><br>
                              <input type="text" value="<%= Account.find(@landingpage.account_id).name %>" name="account[name]" id="account_name" class="form-control">
                            </div>
                            <div class="actions">
                              <input type="submit" name="commit" class="btn btn-primary" value="Update" data-disable-with="Update">
                            </div>
                          </div>
                          <p class="text-muted mb-0">@<%= Account.find(@landingpage.account_id).landingpage_url %></p>
                        </div>
                        <div class="card-footer p-4 pt-0 border-top-0 bg-transparent">
                          <div class="d-flex justify-content-center flex-wrap gap-2">
                            <div onclick="toggle('facebook');" class="social-media-btn social_facebook btn btn-floating">
                              <i class="bi bi-facebook"></i>
                            </div>
                            <div onclick="toggle('twitter');" class="social-media-btn social_twitter btn btn-floating">
                              <i class="bi bi-twitter"></i>
                            </div>
                            <div onclick="toggle('github');" class="social-media-btn social_github btn btn-floating">
                              <i class="bi bi-github"></i>
                            </div>
                            <div onclick="toggle('linkedin');" class="social-media-btn social_linkedin btn btn-floating">
                              <i class="bi bi-linkedin"></i>
                            </div>
                          </div>
                          <input type="text" value="<%= Account.find(@landingpage.account_id).twitter %>" name="account[twitter]" class="form-control d-none mt-3">
                          <input type="text" value="<%= Account.find(@landingpage.account_id).github %>" name="account[github]" class="form-control d-none mt-3">
                          <input type="text" value="<%= Account.find(@landingpage.account_id).facebook %>" name="account[facebook]" class="form-control d-none mt-3">
                          <input type="text" value="<%= Account.find(@landingpage.account_id).linkedin %>" name="account[linkedin]" class="form-control d-none mt-3">
                        </div>
                      </div>
                    </form>
                  </div>
                </div>
              </div>
            </section>

            <section id="blocks-section" class="container py-4">
              <div class="section-heading mb-3">
                <div>
                  <h3 class="mb-1">Blocks</h3>
                  <p class="mb-0 text-muted">Arrange your links and update each card as needed.</p>
                </div>
              </div>
              <div data-controller="drag" data-drag-url="/blocks/:id/move" class="link-list">
                <% @blocks.order(position: :asc).each do |block| %>
                  <div data-id="<%= block.id %>" class="block-container">
                    <div class="preview-form-container d-flex w-100">
                      <div class="link-card w-100" aria-current="true">
                        <i class="drag-list-icon fs-3 align-self-center bi bi-grip-vertical text-muted"></i>
                        <% if block.block_image.attached? %>
                          <img src="https://storage.googleapis.com/rails_link_in_bio_images/<%= block.block_image.key %>" alt="Image for <%= block.title %>" />
                        <% else %>
                          <div class="link-icon"><i class="bi bi-arrow-up-right-circle"></i></div>
                        <% end %>
                        <div class="d-flex gap-2 w-100 justify-content-between align-items-center">
                          <div class="flex-grow-1">
                            <h6 class="mb-0"><%= block.title %></h6>
                            <p class="mb-0 link-copy"><%= block.content %></p>
                          </div>
                          <button type="button" class="btn btn-light edit-inline-btn" onclick="showEditBlock(this);"><i class="bi bi-pencil-square"></i></button>
                        </div>
                      </div>
                    </div>
                    <div class="d-none edit-form-container mt-3">
                      <%= render "blocks/form", block: block %>
                    </div>
                  </div>
                <% end %>
              </div>
              <div class="add-block-container mt-3">
                <div class="list-group w-auto"></div>
              </div>
              <button class="mt-4 btn btn-primary w-100 add-block-btn" onclick="showAddBlock(this);">
                <i class="bi bi-plus-circle me-2"></i>Add a new block
              </button>
            </section>
          </div>
        </div>

        <div class="tab-pane fade" id="nav-theme" role="tabpanel" aria-labelledby="nav-theme-tab" tabindex="0">
          <div class="container py-3">
            <h4 class="mb-4">Theme settings</h4>
            <form action="/landingpages/<%= @landingpage.id %>/edit" method="put">
              <div class="row g-4">
                <div class="col-md-6">
                  <div class="mb-3">
                    <label for="main-page-background-color" class="form-label">Main page background</label>
                    <input type="color" name="landingpage[main_bg_colour]" class="form-control form-control-color" id="main-page-background-color" value="<%= @landingpage.main_bg_colour %>" title="Choose your color">
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="mb-3">
                    <label for="profile-background-color" class="form-label">Profile section background</label>
                    <input type="color" name="landingpage[profile_bg_colour]" class="form-control form-control-color" id="profile-background-color" value="<%= @landingpage.profile_bg_colour %>" title="Choose your color">
                  </div>
                </div>
                <div class="col-12">
                  <button type="submit" class="w-100 btn btn-primary">Save theme settings</button>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function showAddBlock(e) {
    e.parentElement.querySelector(".add-block-container > .list-group").innerHTML += "<%= escape_javascript(render "blocks/form", block: @new_block) %><br/>";
    e.parentElement.querySelector(".add-block-container > .list-group").lastChild.scrollIntoView();
  }

  function showEditBlock(e) {
    let preview_form_container = e.closest(".block-container").querySelector(".preview-form-container");
    let edit_form_container = e.closest(".block-container").querySelector(".edit-form-container");

    preview_form_container.classList.add("d-none");
    edit_form_container.classList.remove("d-none");
  }

  function hideEditBlock(e, does_exist) {
    let blockContainer = e.closest(".block-container");

    if (does_exist && blockContainer) {
      let preview_form_container = blockContainer.querySelector(".preview-form-container");
      let edit_form_container = blockContainer.querySelector(".edit-form-container");

      if (preview_form_container) {
        preview_form_container.classList.remove("d-none");
      }

      if (edit_form_container) {
        edit_form_container.classList.add("d-none");
      }
    } else if (e.closest("form")) {
      e.closest("form").remove();
    }
  }

  async function deleteBlock(e) {
    let block_id = e.getAttribute("data-id");

    if (!block_id) {
      return;
    }

    await fetch(`/blocks/${block_id}`, {
      method: "DELETE",
      headers: {
        "Content-Type": "application/json",
        "Accept": "application/json"
      }
    });

    e.closest(".block-container").remove();
  }

  function toggle(social_media) {
    let all_social_media_btns = document.querySelectorAll(`.social-media-btn:not(.social_${social_media})`);
    let social_media_input = document.querySelector(`input[name="account[${social_media}]"]`);

    all_social_media_btns.forEach((btn) => {
      btn.classList.toggle("invisible");
    });
    social_media_input.classList.toggle("d-none");
  }

  document.addEventListener("change", function(event) {
    if (event.target.matches("input[type='file'][name='block[block_image]']")) {
      let preview = event.target.closest(".block-form")?.querySelector("[data-block-preview='true']") || event.target.closest("form")?.querySelector("[data-block-preview='true']");
      if (preview && event.target.files && event.target.files[0]) {
        preview.src = URL.createObjectURL(event.target.files[0]);
      }
    }
  });

  document.querySelector("#avatar").addEventListener("change", function() {
    let file = this.files[0];
    let reader = new FileReader();
    reader.onloadend = function() {
      document.querySelector("#profile-image").src = reader.result;
    }
    if (file) {
      reader.readAsDataURL(file);
    } else {
      document.querySelector("#profile-image").src = "";
    }
  });

  document.querySelector("#main-page-background-color").addEventListener("change", function(e) {
    document.querySelector("#main-bg-color-container").style.backgroundColor = e.target.value;
  });

  document.querySelector("#profile-background-color").addEventListener("change", function() {
    document.querySelector("#profile").style.backgroundColor = this.value;
  });
</script>
